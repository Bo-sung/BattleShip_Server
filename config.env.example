# BattleShip 서버 환경 설정 예시
# 이 파일을 복사하여 .env 로 저장 후 실제 값으로 수정하세요
#
# 개발: cp config.env.example .env
# 배포: deploy.py 실행 시 deploy.env 로 저장하여 자동 업로드됨
# (.env / deploy.env 모두 .gitignore에 등록되어 있습니다)

# MySQL 연결 문자열
DB_CONNECTION=Server=localhost;Database=battleship;User=root;Password=your_password_here

# Redis 연결 문자열
REDIS_CONNECTION=localhost:6379

# LobbyServer 호스트 (AuthServer에서 클라이언트에게 전달)
LOBBY_HOST=127.0.0.1

# LobbyServer 포트
LOBBY_PORT=7002

# GameSession 호스트 (LobbyServer에서 클라이언트에게 전달)
GAME_SESSION_HOST=127.0.0.1

# GameSession 실행 파일 경로 (LobbyServer가 게임 세션을 직접 실행할 때 사용)
# macOS:   /Users/<user>/battleship/gamesession/BattleShip.GameSession
# Linux:   /home/<user>/battleship/gamesession/BattleShip.GameSession
# Windows: C:\battleship\gamesession\BattleShip.GameSession.exe
GAME_SESSION_EXE_PATH=
